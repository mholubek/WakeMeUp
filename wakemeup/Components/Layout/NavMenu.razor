@inject UiTextService Texts
@inject WakeMeUp.Domain.AppState AppState

<aside class="sidebar-shell">
    <div class="sidebar-mobile-bar">
        <div class="brand-block">
            <div class="brand-mark">WU</div>
            <div>
                <p class="brand-title">@Texts["AppName"]</p>
                <p class="brand-copy">@Texts["BrandSection"]</p>
            </div>
        </div>

        <button class="menu-toggle" type="button" @onclick="ToggleMenu" aria-label="@Texts["OpenMenu"]">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>

    <div class="sidebar-panel @(isMenuOpen ? "is-open" : string.Empty)">
        <div class="brand-block sidebar-brand-desktop">
            <div class="brand-mark">WU</div>
            <div>
                <p class="brand-title">@Texts["AppName"]</p>
                <p class="brand-copy">@Texts["BrandSection"]</p>
            </div>
        </div>

        <nav class="nav flex-column nav-pills gap-2">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All" @onclick="CloseMenu">
                @Texts["NavAlarmOverview"]
            </NavLink>
            <NavLink class="nav-link" href="settings" @onclick="CloseMenu">
                @Texts["NavSettings"]
            </NavLink>
        </nav>

        <div class="sidebar-menu-actions">
            <button type="button" class="nav-link sidebar-menu-link" @onclick="EnableAllAlarmsAsync">
                @Texts["EnableAllAlarms"]
            </button>
            <button type="button" class="nav-link sidebar-menu-link" @onclick="DisableAllAlarmsAsync">
                @Texts["DisableAllAlarms"]
            </button>
        </div>
    </div>
</aside>

@code {
    private bool isMenuOpen;

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private void CloseMenu()
    {
        isMenuOpen = false;
    }

    private async Task EnableAllAlarmsAsync()
    {
        CloseMenu();
        await AppState.RequestBulkAlarmToggleAsync(true);
    }

    private async Task DisableAllAlarmsAsync()
    {
        CloseMenu();
        await AppState.RequestBulkAlarmToggleAsync(false);
    }
}
