@inherits LayoutComponentBase
@inject IAlarmStore Store
@inject IJSRuntime JS
@inject UiTextService Texts
@implements IDisposable

<div class="app-shell">
    <NavMenu />

    <main class="main-shell">
        <article class="content-shell">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    @Texts["UnexpectedError"]
    <a href="." class="reload">@Texts["Reload"]</a>
    <span class="dismiss">x</span>
</div>

@code {
    private AppSettings settings = new();
    private bool languageInitializationPending;

    protected override async Task OnInitializedAsync()
    {
        Texts.Changed += HandleTextsChanged;
        settings = await Store.GetSettingsAsync();
        Texts.SetLanguage(settings.Language);
        languageInitializationPending = !settings.LanguageInitialized;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!languageInitializationPending)
        {
            return;
        }

        languageInitializationPending = false;

        var preferredLanguage = await JS.InvokeAsync<string?>("wakeMeUpTheme.getPreferredLanguage");
        settings.Language = Texts.ResolveAppLanguage(preferredLanguage);
        settings.LanguageInitialized = true;
        Texts.SetLanguage(settings.Language);
        await Store.SaveSettingsAsync(settings);
    }

    private void HandleTextsChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Texts.Changed -= HandleTextsChanged;
    }
}
