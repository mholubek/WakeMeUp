@page "/not-found"
@layout MainLayout
@inject UiTextService Texts

<PageTitle>@Texts["PageTitleNotFound"]</PageTitle>

<div class="panel-card panel-card-wide">
    <div class="section-heading">
        <div>
            <p class="section-kicker">404</p>
            <h2>@Texts["NotFoundHeadline"]</h2>
        </div>
    </div>

    <p>@Texts["NotFoundText"]</p>
    <a class="btn btn-primary" href="/">@Texts["BackToDashboard"]</a>
</div>
