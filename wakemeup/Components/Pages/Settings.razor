@page "/settings"
@inject IAlarmStore Store
@inject IJSRuntime JS
@inject UiTextService Texts

<PageTitle>@Texts["PageTitleSettings"]</PageTitle>

<div class="panel-card panel-card-wide">
    <div class="section-heading">
        <p class="section-kicker">@Texts["Settings"]</p>
    </div>

    <EditForm Model="settings" OnValidSubmit="SaveSettingsAsync" FormName="app-settings" class="stack-form">
        <div>
            <label class="form-label">@Texts["Theme"]</label>
            <InputSelect class="form-select" @bind-Value="settings.ThemeMode">
                @foreach (var mode in Enum.GetValues<ThemeMode>())
                {
                    <option value="@mode">@GetThemeModeName(mode)</option>
                }
            </InputSelect>
            <div class="form-text">@Texts["ThemeDescription"]</div>
        </div>

        <div>
            <label class="form-label">@Texts["Language"]</label>
            <InputSelect class="form-select" @bind-Value="settings.Language">
                @foreach (var language in Texts.GetSupportedLanguages())
                {
                    <option value="@language.Value">@language.DisplayName</option>
                }
            </InputSelect>
        </div>

        <button type="submit" class="btn btn-primary">@Texts["SaveSettings"]</button>
    </EditForm>

    <div class="status-callout mt-4">
        <p>@Texts["TimeZone"]: @TimeZoneInfo.Local.DisplayName</p>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="toast-banner @(isError ? "toast-banner-error" : "toast-banner-success")" @onclick="DismissStatusMessageAsync">
        @statusMessage
    </div>
}

@code {
    private AppSettings settings = new();
    private bool isError;
    private bool themeSyncPending;
    private string statusMessage = string.Empty;
    private CancellationTokenSource? statusMessageCts;

    protected override async Task OnInitializedAsync()
    {
        settings = await Store.GetSettingsAsync();
        Texts.SetLanguage(settings.Language);
        themeSyncPending = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!themeSyncPending)
        {
            return;
        }

        themeSyncPending = false;
        await ApplyThemeAsync();
    }

    private async Task SaveSettingsAsync()
    {
        settings.LanguageInitialized = true;
        await Store.SaveSettingsAsync(settings);
        Texts.SetLanguage(settings.Language);
        await ApplyThemeAsync();
        ShowStatusMessage(Texts["SettingsSaved"], false);
    }

    private async Task ApplyThemeAsync()
    {
        await JS.InvokeVoidAsync("wakeMeUpTheme.apply", settings.ThemeMode.ToString());
    }

    private string GetThemeModeName(ThemeMode mode)
    {
        return mode switch
        {
            ThemeMode.Auto => Texts["Automatic"],
            ThemeMode.Light => Texts["Light"],
            ThemeMode.Dark => Texts["Dark"],
            _ => mode.ToString()
        };
    }

    private void ShowStatusMessage(string message, bool error)
    {
        statusMessageCts?.Cancel();
        statusMessageCts?.Dispose();

        statusMessage = message;
        isError = error;

        statusMessageCts = new CancellationTokenSource();
        _ = DismissStatusMessageAfterDelayAsync(statusMessageCts.Token);
    }

    private async Task DismissStatusMessageAfterDelayAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(5), cancellationToken);
            await InvokeAsync(DismissStatusMessageAsync);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private Task DismissStatusMessageAsync()
    {
        statusMessageCts?.Cancel();
        statusMessageCts?.Dispose();
        statusMessageCts = null;
        statusMessage = string.Empty;
        StateHasChanged();
        return Task.CompletedTask;
    }
}
