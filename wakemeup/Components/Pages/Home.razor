@page "/"
@inject IAlarmStore Store
@inject AlarmOccurrenceService OccurrenceService
@inject IJSRuntime JS
@inject ILogger<Home> Logger
@inject UiTextService Texts
@inject AlarmMutationService AlarmMutations

<PageTitle>@Texts["PageTitleHome"]</PageTitle>

<div class="dashboard-grid">
    <section class="panel-card panel-card-wide">
        <div class="section-heading alarm-overview-heading">
            <div>
                <p class="section-kicker">@Texts["Alarms"]</p>
                <h2>@Texts["AlarmOverview"]</h2>
            </div>
            <button class="btn btn-primary" @onclick="StartCreate">
                <span class="btn-icon" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="currentColor">
                        <path d="M7 2h2v5h5v2H9v5H7V9H2V7h5z" />
                    </svg>
                </span>
                <span>@Texts["NewAlarm"]</span>
            </button>
        </div>

        @if (isLoading)
        {
            <div class="empty-state">
                <div class="spinner-border text-primary" role="status"></div>
                <p>@Texts["LoadingSavedAlarms"]</p>
            </div>
        }
        else if (alarms.Count == 0)
        {
            <div class="empty-state">
                <h3>@Texts["NoAlarmsYet"]</h3>
                <p>@Texts["NoAlarmsYetText"]</p>
            </div>
        }
        else
        {
            <div class="alarm-list">
                @foreach (var alarm in alarms)
                {
                    var nextOccurrence = OccurrenceService.GetNextOccurrence(alarm, DateTimeOffset.Now);
                    <article class="alarm-card">
                        <div class="alarm-main">
                            <div class="alarm-time-column">
                                <div class="alarm-time">@alarm.Time.ToString("HH\\:mm")</div>
                                <div class="alarm-inline-toggle">
                                    <div class="form-check form-switch alarm-switch">
                                        <InputCheckbox class="form-check-input"
                                                       Value="alarm.IsEnabled"
                                                       ValueChanged="@(value => ToggleAlarm(alarm, value))"
                                                       ValueExpression="@(() => alarm.IsEnabled)" />
                                    </div>
                                </div>
                                <div class="form-check form-switch alarm-switch alarm-switch-desktop">
                                    <InputCheckbox class="form-check-input"
                                                   Value="alarm.IsEnabled"
                                                   ValueChanged="@(value => ToggleAlarm(alarm, value))"
                                                   ValueExpression="@(() => alarm.IsEnabled)" />
                                </div>
                            </div>
                            <div class="alarm-content">
                                <div class="alarm-title-row">
                                    <h3>@alarm.Name</h3>
                                    <div class="alarm-badges">
                                        <span class="badge text-bg-secondary">@GetRepeatLabel(alarm)</span>
                                        @if (alarm.IsEnabled)
                                        {
                                            <span class="badge text-bg-success">@Texts["Enabled"]</span>
                                        }
                                        else
                                        {
                                            <span class="badge text-bg-dark">@Texts["Disabled"]</span>
                                        }
                                    </div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(alarm.Description))
                                {
                                    <p class="alarm-description">@alarm.Description</p>
                                }
                                <div class="alarm-meta">
                                    <span>@Texts["NextTrigger"]: @FormatOccurrence(nextOccurrence)</span>
                                </div>
                            </div>
                        </div>

                        <div class="alarm-actions">
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => EditAlarm(alarm)">
                                <span class="btn-icon" aria-hidden="true">
                                    <svg viewBox="0 0 16 16" fill="currentColor">
                                        <path d="M12.854 1.146a.5.5 0 0 1 .707 0l1.586 1.586a.5.5 0 0 1 0 .707l-8.5 8.5L4 12l.061-2.646zM3 13.5A1.5 1.5 0 0 0 4.5 15h8a.5.5 0 0 0 0-1h-8a.5.5 0 0 1-.5-.5v-8a.5.5 0 0 0-1 0z" />
                                    </svg>
                                </span>
                                <span>@Texts["Edit"]</span>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteAlarm(alarm.Id)">
                                <span class="btn-icon" aria-hidden="true">
                                    <svg viewBox="0 0 16 16" fill="currentColor">
                                        <path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0A.5.5 0 0 1 8.5 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z" />
                                        <path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1 0-2H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1zM4 4v9a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4z" />
                                    </svg>
                                </span>
                                <span>@Texts["Delete"]</span>
                            </button>
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

@if (isEditorOpen)
{
    <div class="modal-backdrop fade show"></div>
    <div class="editor-modal-wrap" @onclick="HandleBackdropClick">
        <section class="editor-modal panel-card"
                 tabindex="0"
                 @ref="editorModalRef"
                 @onclick:stopPropagation="true"
                 @onkeydown="HandleModalKeyDown">
            <div class="section-heading">
                <div>
                    <p class="section-kicker">@Texts["Editor"]</p>
                    <h2>@(editor.IsEditMode ? Texts["EditAlarm"] : Texts["NewAlarm"])</h2>
                </div>
                <button type="button" class="btn btn-outline-secondary btn-sm editor-close-button" @onclick="CloseEditor">
                    <span class="btn-icon" aria-hidden="true">
                        <svg viewBox="0 0 16 16" fill="currentColor">
                            <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708" />
                        </svg>
                    </span>
                    <span>@Texts["Close"]</span>
                </button>
            </div>

            <EditForm Model="editor" OnValidSubmit="SaveAlarmAsync" FormName="alarm-editor" class="stack-form">
                <div>
                    <label class="form-label">@Texts["Name"]</label>
                    <InputText class="form-control" @bind-Value="editor.Name" />
                </div>

                <div>
                    <label class="form-label">@Texts["Time"]</label>
                    <InputText class="form-control" type="time" @bind-Value="editor.TimeText" />
                </div>

                <div>
                    <label class="form-label">@Texts["Repeat"]</label>
                    <InputSelect class="form-select" @bind-Value="editor.RepeatMode">
                        @foreach (var mode in Enum.GetValues<RepeatMode>())
                        {
                            <option value="@mode">@GetRepeatModeName(mode)</option>
                        }
                    </InputSelect>
                </div>

                @if (editor.RepeatMode == RepeatMode.CustomDays)
                {
                    <div>
                        <label class="form-label">@Texts["ChooseDays"]</label>
                        <div class="weekday-grid">
                            @foreach (var day in weekdays)
                            {
                                <label class="weekday-pill">
                                    <input type="checkbox"
                                           checked="@editor.Days.HasFlag(day.Flag)"
                                           @onchange="args => ToggleEditorDay(day.Flag, args.Value is true)" />
                                    <span>@day.ShortName</span>
                                </label>
                            }
                        </div>
                    </div>
                }

                <div>
                    <label class="form-label">@Texts["Note"]</label>
                    <InputTextArea class="form-control" rows="3" @bind-Value="editor.Description" />
                </div>

                <div class="form-check form-switch">
                    <InputCheckbox class="form-check-input" @bind-Value="editor.IsEnabled" />
                    <label class="form-check-label">@Texts["AlarmIsEnabled"]</label>
                </div>

                <div class="editor-actions">
                    <button type="submit" class="btn btn-primary">
                        <span class="btn-icon" aria-hidden="true">
                            <svg viewBox="0 0 16 16" fill="currentColor">
                                <path d="M2.5 1A1.5 1.5 0 0 0 1 2.5v11A1.5 1.5 0 0 0 2.5 15h11a1.5 1.5 0 0 0 1.5-1.5v-8.793a1.5 1.5 0 0 0-.44-1.06L12.354.94A1.5 1.5 0 0 0 11.293.5H2.5zM3 2h8v3H3zm0 5h10v6.5a.5.5 0 0 1-.5.5H11v-3.5A1.5 1.5 0 0 0 9.5 9h-3A1.5 1.5 0 0 0 5 10.5V14H3.5a.5.5 0 0 1-.5-.5zm3 7v-3.5a.5.5 0 0 1 .5-.5h3a.5.5 0 0 1 .5.5V14z" />
                            </svg>
                        </span>
                        <span>@Texts["SaveAlarm"]</span>
                    </button>
                </div>
            </EditForm>
        </section>
    </div>
}

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="toast-banner @(isError ? "toast-banner-error" : "toast-banner-success")" @onclick="DismissStatusMessageAsync">
        @statusMessage
    </div>
}

@code {
    private (WeekdaySelection Flag, string ShortName)[] weekdays = [];
    private readonly AlarmEditorModel editor = new();
    private List<AlarmDefinition> alarms = [];
    private bool isLoading = true;
    private bool isError;
    private bool isEditorOpen;
    private bool focusEditorPending;
    private ElementReference editorModalRef;
    private string statusMessage = string.Empty;
    private CancellationTokenSource? statusMessageCts;

    protected override async Task OnInitializedAsync()
    {
        BuildWeekdays();
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!focusEditorPending)
        {
            return;
        }

        focusEditorPending = false;
        await JS.InvokeVoidAsync("wakeMeUpUi.focusElement", editorModalRef);
    }

    private void BuildWeekdays()
    {
        weekdays =
        [
            (WeekdaySelection.Monday, Texts["Mon"]),
            (WeekdaySelection.Tuesday, Texts["Tue"]),
            (WeekdaySelection.Wednesday, Texts["Wed"]),
            (WeekdaySelection.Thursday, Texts["Thu"]),
            (WeekdaySelection.Friday, Texts["Fri"]),
            (WeekdaySelection.Saturday, Texts["Sat"]),
            (WeekdaySelection.Sunday, Texts["Sun"])
        ];
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        BuildWeekdays();
        alarms = (await Store.GetAlarmsAsync()).OrderBy(x => x.Time).ToList();
        isLoading = false;
    }

    private void StartCreate()
    {
        ResetEditor();
        editor.Name = $"{Texts["NewAlarm"]} {alarms.Count + 1}";
        isEditorOpen = true;
        focusEditorPending = true;
    }

    private void EditAlarm(AlarmDefinition alarm)
    {
        editor.Load(alarm);
        isEditorOpen = true;
        focusEditorPending = true;
    }

    private async Task ToggleAlarm(AlarmDefinition alarm, bool isEnabled)
    {
        try
        {
            var updatedAlarm = AlarmMutations.ApplyEnabledState(alarm, isEnabled);
            await Store.SaveAlarmAsync(updatedAlarm);
            Logger.LogInformation(
                "[{LoggedAt}] Alarm updated: Name='{AlarmName}', Time='{AlarmTime}', Description='{AlarmDescription}', Enabled={IsEnabled}",
                GetLogTimestamp(),
                updatedAlarm.Name,
                updatedAlarm.Time.ToString("HH\\:mm"),
                GetLogDescription(updatedAlarm.Description),
                updatedAlarm.IsEnabled);
            ShowStatusMessage(updatedAlarm.IsEnabled ? Texts["AlarmEnabled"] : Texts["AlarmDisabled"], false);
            await LoadAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(
                exception,
                "[{LoggedAt}] Error updating alarm: Name='{AlarmName}', Time='{AlarmTime}', Description='{AlarmDescription}'",
                GetLogTimestamp(),
                alarm.Name,
                alarm.Time.ToString("HH\\:mm"),
                GetLogDescription(alarm.Description));
            ShowStatusMessage(Texts["UnableUpdateAlarm"], true);
        }
    }

    private async Task DeleteAlarm(Guid alarmId)
    {
        var alarm = alarms.FirstOrDefault(x => x.Id == alarmId);

        try
        {
            await Store.DeleteAlarmAsync(alarmId);
            if (alarm is not null)
            {
                Logger.LogInformation(
                    "[{LoggedAt}] Alarm deleted: Name='{AlarmName}', Time='{AlarmTime}', Description='{AlarmDescription}'",
                    GetLogTimestamp(),
                    alarm.Name,
                    alarm.Time.ToString("HH\\:mm"),
                    GetLogDescription(alarm.Description));
            }

            ShowStatusMessage(Texts["AlarmDeleted"], false);
            if (editor.Id == alarmId)
            {
                CloseEditor();
            }
            await LoadAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(
                exception,
                "[{LoggedAt}] Error deleting alarm: Name='{AlarmName}', Time='{AlarmTime}', Description='{AlarmDescription}'",
                GetLogTimestamp(),
                alarm?.Name ?? "Unknown",
                alarm?.Time.ToString("HH\\:mm") ?? "Unknown",
                GetLogDescription(alarm?.Description));
            ShowStatusMessage(Texts["UnableDeleteAlarm"], true);
        }
    }

    private async Task SaveAlarmAsync()
    {
        if (!editor.TryBuild(AlarmMutations, out var alarm, out var validationError))
        {
            ShowStatusMessage(GetValidationMessage(validationError), true);
            return;
        }

        try
        {
            await Store.SaveAlarmAsync(alarm);
            Logger.LogInformation(
                "[{LoggedAt}] Alarm set: Name='{AlarmName}', Time='{AlarmTime}', Description='{AlarmDescription}'",
                GetLogTimestamp(),
                alarm.Name,
                alarm.Time.ToString("HH\\:mm"),
                GetLogDescription(alarm.Description));
            ShowStatusMessage(editor.IsEditMode ? Texts["AlarmUpdated"] : Texts["AlarmCreated"], false);
            CloseEditor();
            await LoadAsync();
        }
        catch (Exception exception)
        {
            Logger.LogError(
                exception,
                "[{LoggedAt}] Error saving alarm: Name='{AlarmName}', Time='{AlarmTime}', Description='{AlarmDescription}'",
                GetLogTimestamp(),
                alarm.Name,
                alarm.Time.ToString("HH\\:mm"),
                GetLogDescription(alarm.Description));
            ShowStatusMessage(Texts["UnableSaveAlarm"], true);
        }
    }

    private void ToggleEditorDay(WeekdaySelection day, bool enabled)
    {
        if (enabled)
        {
            editor.Days |= day;
        }
        else
        {
            editor.Days &= ~day;
        }
    }

    private void ResetEditor()
    {
        editor.Reset();
        editor.Name = Texts["NewAlarm"];
    }

    private void CloseEditor()
    {
        ResetEditor();
        isEditorOpen = false;
    }

    private void HandleBackdropClick()
    {
        CloseEditor();
    }

    private void HandleModalKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Escape")
        {
            CloseEditor();
        }
    }

    private string GetRepeatModeName(RepeatMode mode)
    {
        return mode switch
        {
            RepeatMode.Never => Texts["RepeatNever"],
            RepeatMode.Daily => Texts["RepeatDaily"],
            RepeatMode.Weekdays => Texts["RepeatWeekdays"],
            RepeatMode.Weekends => Texts["RepeatWeekends"],
            RepeatMode.CustomDays => Texts["RepeatCustomDays"],
            _ => mode.ToString()
        };
    }

    private string GetRepeatLabel(AlarmDefinition alarm)
    {
        return alarm.RepeatMode switch
        {
            RepeatMode.CustomDays when alarm.Days != WeekdaySelection.None => string.Join(", ", weekdays.Where(x => alarm.Days.HasFlag(x.Flag)).Select(x => x.ShortName)),
            _ => GetRepeatModeName(alarm.RepeatMode)
        };
    }

    private string FormatOccurrence(DateTimeOffset? occurrence)
    {
        return occurrence.HasValue
            ? occurrence.Value.LocalDateTime.ToString("g", System.Globalization.CultureInfo.CurrentCulture)
            : Texts["NotScheduled"];
    }

    private static string GetLogDescription(string? description)
    {
        return description?.Trim() ?? string.Empty;
    }

    private static string GetLogTimestamp()
    {
        return DateTimeOffset.Now.ToString("yyyy-MM-dd HH:mm:ss zzz");
    }

    private string GetValidationMessage(AlarmValidationError validationError)
    {
        return validationError.Code switch
        {
            "name_required" => Texts["ValidationNameRequired"],
            "name_too_long" => Texts["ValidationNameTooLong"],
            "time_format_invalid" => Texts["ValidationTimeFormat"],
            "description_too_long" => Texts["ValidationDescriptionTooLong"],
            "custom_days_required" => Texts["ValidationSelectDay"],
            _ => validationError.Message
        };
    }

    private void ShowStatusMessage(string message, bool error)
    {
        statusMessageCts?.Cancel();
        statusMessageCts?.Dispose();

        statusMessage = message;
        isError = error;

        statusMessageCts = new CancellationTokenSource();
        _ = DismissStatusMessageAfterDelayAsync(statusMessageCts.Token);
    }

    private async Task DismissStatusMessageAfterDelayAsync(CancellationToken cancellationToken)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(5), cancellationToken);
            await InvokeAsync(DismissStatusMessageAsync);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private Task DismissStatusMessageAsync()
    {
        statusMessageCts?.Cancel();
        statusMessageCts?.Dispose();
        statusMessageCts = null;
        statusMessage = string.Empty;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private sealed class AlarmEditorModel
    {
        public Guid Id { get; set; } = Guid.NewGuid();

        [StringLength(80)]
        public string Name { get; set; } = string.Empty;

        public string TimeText { get; set; } = "07:00";

        [StringLength(160)]
        public string Description { get; set; } = string.Empty;

        public bool IsEnabled { get; set; } = true;
        public bool OriginalIsEnabled { get; set; } = true;
        public RepeatMode RepeatMode { get; set; } = RepeatMode.Never;
        public WeekdaySelection Days { get; set; } = WeekdaySelection.None;
        public bool IsEditMode { get; set; }
        public DateTimeOffset? LastProcessedOccurrenceUtc { get; set; }
        public DateTimeOffset? LastTriggeredUtc { get; set; }
        public string LastResultMessage { get; set; } = string.Empty;
        public DateTimeOffset CreatedUtc { get; set; } = DateTimeOffset.UtcNow;

        public void Load(AlarmDefinition alarm)
        {
            Id = alarm.Id;
            Name = alarm.Name;
            TimeText = alarm.Time.ToString("HH\\:mm");
            Description = alarm.Description;
            IsEnabled = alarm.IsEnabled;
            OriginalIsEnabled = alarm.IsEnabled;
            RepeatMode = alarm.RepeatMode;
            Days = alarm.Days;
            IsEditMode = true;
            LastProcessedOccurrenceUtc = alarm.LastProcessedOccurrenceUtc;
            LastTriggeredUtc = alarm.LastTriggeredUtc;
            LastResultMessage = alarm.LastResultMessage;
            CreatedUtc = alarm.CreatedUtc;
        }

        public void Reset()
        {
            Id = Guid.NewGuid();
            Name = string.Empty;
            TimeText = "07:00";
            Description = string.Empty;
            IsEnabled = true;
            OriginalIsEnabled = true;
            RepeatMode = RepeatMode.Never;
            Days = WeekdaySelection.None;
            IsEditMode = false;
            LastProcessedOccurrenceUtc = null;
            LastTriggeredUtc = null;
            LastResultMessage = string.Empty;
            CreatedUtc = DateTimeOffset.UtcNow;
        }

        public bool TryBuild(AlarmMutationService alarmMutations, out AlarmDefinition alarm, out AlarmValidationError validationError)
        {
            validationError = new AlarmValidationError(string.Empty, string.Empty, string.Empty);
            alarm = new AlarmDefinition();
            var existingAlarm = IsEditMode
                ? new AlarmDefinition
                {
                    Id = Id,
                    Name = Name,
                    Description = Description,
                    Time = TimeOnly.TryParse(TimeText, out var existingTime) ? existingTime : new TimeOnly(7, 0),
                    IsEnabled = OriginalIsEnabled,
                    RepeatMode = RepeatMode,
                    Days = Days,
                    CreatedUtc = CreatedUtc,
                    LastProcessedOccurrenceUtc = LastProcessedOccurrenceUtc,
                    LastTriggeredUtc = LastTriggeredUtc,
                    LastResultMessage = LastResultMessage
                }
                : null;

            if (!alarmMutations.TryBuild(
                    new AlarmMutationInput(
                        Id,
                        Name,
                        Description,
                        TimeText,
                        IsEnabled,
                        RepeatMode,
                        Days),
                    existingAlarm,
                    out alarm,
                    out var error))
            {
                validationError = error!;
                return false;
            }

            return true;
        }
    }
}
