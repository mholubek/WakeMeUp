@page "/Error"
@using System.Diagnostics

<PageTitle>Application error</PageTitle>

<div class="panel-card panel-card-wide">
    <div class="section-heading">
        <div>
            <p class="section-kicker">Error</p>
            <h2>An error occurred while processing your request</h2>
        </div>
    </div>

    @if (ShowRequestId)
    {
        <p><strong>Request ID:</strong> <code>@RequestId</code></p>
    }

    <p>If the problem persists, check the container logs and the Home Assistant connection setup.</p>
</div>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
